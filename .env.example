# Auth.js / Google OAuth
# 請至 Google Cloud Console 建立 OAuth 用戶端（網頁應用程式）
# 本機重新導向 URI：http://localhost:3000/api/auth/callback/google
# 正式環境重新導向 URI：https://你的網域/api/auth/callback/google
AUTH_SECRET=請改成一組隨機字串
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_URL=http://localhost:3000
# Vercel 等雲端部署建議設為 true（本專案 src/auth.ts 已 trustHost: true）
AUTH_TRUST_HOST=true

# 管理員信箱（逗號分隔，需與 Google 登入信箱一致）
ADMIN_EMAILS=you@gmail.com

# PostgreSQL（Prisma）
# 本機 Docker：docker compose up -d
# 正式環境：Neon 等雲端 Postgres 連線字串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evote?schema=public"
